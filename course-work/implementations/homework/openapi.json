    "components": {
        "schemas": {
            "CreateStudyGoalDto": {
                "required": [
                    "goalTitle"
                ],
                "type": "object",
                "properties": {
                    "goalTitle": {
                        "maxLength": 100,
                        "minLength": 1,
                        "type": "string"
                    },
                    "targetHours": {
                        "type": "number",
                        "format": "double"
                    },
                    "deadline": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "completed": {
                        "type": "boolean"
                    },
                    "priority": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "userId": {
                        "type": "integer",
                        "format": "int32"
                    }
                },
                "additionalProperties": false
            },
            "CreateStudySessionDto": {
                "required": [
                    "subject",
                    "title"
                ],
                "type": "object",
                "properties": {
                    "title": {
                        "maxLength": 100,
                        "minLength": 1,
                        "type": "string"
                    },
                    "subject": {
                        "maxLength": 50,
                        "minLength": 1,
                        "type": "string"
                    },
                    "durationMinutes": {
                        "type": "integer",
                        "format": "int32"
                    },
                    "sessionDate": {
                        "type": "string",
                        "format": "date-time"
                    },
                    "difficulty": {
                        "type": "number",
                        "format": "double"
                    },
                    "userId": {
                        "type": "integer",
                        "format": "int32"
                    }
                },
                "additionalProperties": false
            },
            "CreateUserDto": {
                "required": [
                    "email",
                    "password",
                    "role",
                    "username"
                ],
                "type": "object",
                "properties": {
                    "username": {
                        "maxLength": 50,
                        "minLength": 1,
                        "type": "string"
                    },
                    "email": {
                        "maxLength": 100,
                        "minLength": 1,
                        "type": "string"
                    },
                    "password": {
                        "maxLength": 150,
                        "minLength": 1,
                        "type": "string"
                    },
                    "role": {
                        "maxLength": 20,
                        "minLength": 1,
                        "type": "string"
                    },
                    "age": {
                        "type": "integer",
                        "format": "int32"
                    }
                },
                "additionalProperties": false
            },
            "UpdateUserDto": {
                "required": [
                    "email",
                    "password",
                    "role",
                    "username"
                ],
                "type": "object",
                "properties": {
                    "username": {
                        "maxLength": 50,
                        "minLength": 1,
                        "type": "string"
                    },
                    "email": {
                        "maxLength": 100,
                        "minLength": 1,
                        "type": "string"
                    },
                    "password": {
                        "maxLength": 100,
                        "minLength": 1,
                        "type": "string"
                    },
                    "role": {
                        "maxLength": 30,
                        "minLength": 1,
                        "type": "string"
                    },
                    "age": {
                        "type": "integer",
                        "format": "int32"
                    }
                },
                "additionalProperties": false
            }
        }
